# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET:
# OAuth 2.0 Web Client credentials used only by the server-side authorization-code flow.
# Configure the authorized redirect URI as:
#   ${APP_URL}/api/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID="MY_GOOGLE_OAUTH_CLIENT_ID"
GOOGLE_OAUTH_CLIENT_SECRET="MY_GOOGLE_OAUTH_CLIENT_SECRET"

# OAUTH_STATE_SECRET:
# High-entropy secret used to sign expiring OAuth state, PKCE cookies, and short-lived
# live WebSocket auth tickets. Do not reuse public Firebase config values.
OAUTH_STATE_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# KMS_KEY_NAME:
# Full Cloud KMS crypto key resource used to encrypt Google refresh tokens.
# Example:
# projects/MY_PROJECT/locations/global/keyRings/MY_RING/cryptoKeys/MY_KEY
KMS_KEY_NAME="MY_KMS_KEY_NAME"

# FIRESTORE_DATABASE_ID:
# Firestore database ID where encrypted refresh-token vault records are stored.
FIRESTORE_DATABASE_ID="(default)"
